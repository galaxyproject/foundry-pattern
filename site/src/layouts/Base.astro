---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { href: `${base}/pattern`, label: "The Pattern" },
  { href: `${base}/case`, label: "The Case" },
  { href: `${base}/instances`, label: "Instances" },
  { href: `${base}/blog`, label: "Blog" },
  { href: `${base}/search`, label: "Search" },
];
const here = Astro.url.pathname.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · The Foundry Pattern</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='13' font-size='13'%3E%E2%9A%92%EF%B8%8F%3C/text%3E%3C/svg%3E" />
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="heat-strip"></div>
    <header class="border-b" style="border-color: var(--rule); background: var(--soot)">
      <div class="mx-auto max-w-5xl px-5 py-4 flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href={`${base}/`} class="no-underline flex items-baseline gap-2" style="color: var(--ink)">
          <span style="font-size:1.15rem">⚒️</span>
          <span class="text-lg font-semibold uppercase" style="font-family: var(--font-display); letter-spacing: 0.04em">
            The Foundry Pattern
          </span>
        </a>
        <nav class="flex gap-x-6 gap-y-1 flex-wrap ml-auto text-[0.82rem] uppercase" style="font-family: var(--font-display); letter-spacing: 0.1em; font-weight: 500">
          {nav.map((n) => (
            <a
              href={n.href}
              class="no-underline transition-colors"
              style={here.startsWith(n.href) ? "color: var(--ember)" : "color: var(--ash)"}
            >
              {n.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl px-5 pt-5 pb-12 flex-1">
      <slot />
    </main>

    <footer class="border-t mt-16" style="border-color: var(--rule); background: var(--soot)">
      <div class="mx-auto max-w-5xl px-5 py-10 text-sm flex flex-col gap-6 sm:flex-row sm:justify-between" style="color: var(--muted)">
        <div class="max-w-md">
          <p class="kicker">The Foundry Pattern</p>
          <p class="mt-3 leading-relaxed" style="color: var(--muted)">
            An inspectable knowledge base of deep domain knowledge, read by humans and
            acted on by agents, that casts skills which don't rot: frozen and
            provenance-stamped. A substrate to extend, not a template to stamp.
          </p>
        </div>
        <div class="flex flex-col gap-1.5">
          <span class="uppercase text-xs" style="font-family: var(--font-display); letter-spacing: 0.16em; color: var(--ash)">Instances</span>
          <a href="https://galaxyproject.github.io/foundry/">Galaxy Workflow Foundry ↗</a>
          <a href="https://github.com/jmchilton/statistical-genomics-foundry">Statistical Genomics Foundry ↗</a>
        </div>
      </div>
    </footer>
  </body>
</html>
