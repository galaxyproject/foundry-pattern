---
interface Props {
  href: string;
  title: string;
  description?: string;
  badge?: string;
}
const { href, title, description, badge } = Astro.props;
---
<a href={href} class="card block rounded-lg p-5 no-underline">
  <div class="flex items-baseline gap-2 flex-wrap">
    <span class="font-semibold text-[1.05rem]" style="font-family: var(--font-display); color: var(--ink)">{title}</span>
    {badge && <span class="badge">{badge}</span>}
  </div>
  {description && <p class="mt-1.5 text-sm leading-relaxed" style="color: var(--ash)">{description}</p>}
</a>
