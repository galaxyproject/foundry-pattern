---
import { getCollection } from "astro:content";
import DocCard from "./DocCard.astro";

interface Props {
  section: "pattern" | "case" | "instances" | "blog";
  kicker: string;
  title: string;
  intro: string;
}
const { section, kicker, title, intro } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const entries = (await getCollection("docs", (e) => e.data.section === section)).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

function badgeFor(data: any): string | undefined {
  if (data.order === 1 && (section === "case" || section === "blog")) return "flagship";
  if (data.instance_number) return `instance #${data.instance_number}`;
  return undefined;
}
---
<div>
  <p class="kicker">{kicker}</p>
  <h1 class="text-3xl font-bold mt-1">{title}</h1>
  <p class="mt-3 max-w-2xl" style="color: var(--muted)">{intro}</p>

  <div class="mt-8 grid gap-3 sm:grid-cols-2">
    {entries.map((e) => (
      <DocCard
        href={`${base}/${e.id}/`}
        title={e.data.title}
        description={e.data.description}
        badge={badgeFor(e.data)}
      />
    ))}
  </div>
</div>
