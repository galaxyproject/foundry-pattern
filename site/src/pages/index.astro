---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const doors = [
  {
    href: `${base}/pattern`,
    kicker: "The Pattern",
    blurb: "The timeless spec. A knowledge base of Molds, cast into frozen artifacts with provenance — a substrate each domain extends.",
  },
  {
    href: `${base}/case`,
    kicker: "The Case",
    blurb: "The argument: skills should be a packaging format, not a source format. Read the flagship — Skills: Package, Not Source.",
  },
  {
    href: `${base}/instances`,
    kicker: "Instances",
    blurb: "The pattern, twice. Two Foundries that share a substrate and extend it differently per domain — which is where the abstraction is earned.",
  },
  {
    href: `${base}/blog`,
    kicker: "Blog / Lab",
    blurb: "Evidence and experiments — and anything dated, kept here so the spec never carries a date. Start with Blind Regeneration.",
  },
];
---
<Base title="The Foundry Pattern" description="An inspectable knowledge base of deep domain knowledge, read by humans and acted on by agents, that casts skills which don't rot: frozen and provenance-stamped. A substrate to extend, not a template to stamp.">
  <section class="max-w-3xl">
    <p class="kicker">A design pattern for actionable knowledge bases</p>
    <h1 class="text-4xl sm:text-6xl font-semibold mt-4 leading-[1.04]" style="letter-spacing:-0.015em">
      Make the knowledge base <em class="molten">actionable</em>.<br />Cast skills that don't <em class="molten">rot</em>.
    </h1>
    <p class="mt-7 text-lg leading-relaxed" style="color: var(--steel)">
      The Foundry Pattern keeps the knowledge where it belongs. The source of record is an
      inspectable <strong>knowledge base</strong> of deep domain knowledge, authored to be read
      by a human and acted on by an agent. A deterministic <strong>cast</strong> compiles it into
      frozen skill artifacts that carry <strong>provenance</strong> — a <strong>substrate</strong>
      each domain extends with its own knowledge and the checks its work demands.
    </p>
    <p class="mt-4" style="color: var(--muted)">
      It is documented in the abstract because it now has two instances, and abstraction
      earns itself at the diff between them: the substrate holds, and each domain extends it
      differently.
    </p>
  </section>

  <div class="mt-14 grid gap-4 sm:grid-cols-2">
    {doors.map((d, i) => (
      <a href={d.href} class="door group block rounded-xl p-6 no-underline">
        <div class="flex items-center justify-between">
          <span class="cast-num">{String(i + 1).padStart(2, "0")} / 04</span>
          <span class="kicker" style="gap:0">{d.kicker}</span>
        </div>
        <p class="mt-3 leading-relaxed" style="color: var(--steel)">{d.blurb}</p>
        <span class="mt-4 inline-block uppercase text-xs tracking-widest transition-colors" style="font-family: var(--font-display); color: var(--ash)">Enter <span class="group-hover:text-[var(--glow)]" style="color: var(--ember)">→</span></span>
      </a>
    ))}
  </div>
</Base>
