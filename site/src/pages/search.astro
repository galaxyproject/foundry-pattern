---
import Base from "../layouts/Base.astro";
import Search from "astro-pagefind/components/Search";
---
<Base title="Search" description="Search the Foundry Pattern site.">
  <div class="max-w-3xl mx-auto">
    <p class="kicker">Search</p>
    <h1 class="text-3xl font-bold mt-1 mb-6">Search the site</h1>
    <Search id="search" className="pagefind-ui" uiOptions={{ showSubResults: true, showImages: false }} />
    <p class="mt-6 text-sm" style="color: var(--muted)">
      Full-text search is generated at build time; it works on the deployed site and in
      <code>npm run preview</code>, not in the dev server.
    </p>
  </div>
</Base>
