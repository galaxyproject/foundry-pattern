---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base title="Not found" description="That page doesn't exist.">
  <div class="max-w-2xl mx-auto text-center py-16">
    <p class="kicker">404</p>
    <h1 class="text-4xl font-bold mt-2 leading-[1.04]">This page hasn't been cast.</h1>
    <p class="mt-3" style="color: var(--muted)">
      The thing you're after isn't here. Try a door:
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm">
      <a href={`${base}/pattern`}>The Pattern</a>
      <a href={`${base}/case`}>The Case</a>
      <a href={`${base}/instances`}>Instances</a>
      <a href={`${base}/blog`}>Blog</a>
      <a href={`${base}/search`}>Search</a>
    </div>
  </div>
</Base>
